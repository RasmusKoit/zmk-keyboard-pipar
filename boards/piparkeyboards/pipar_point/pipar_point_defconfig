# A Kconfig fragment that is merged as-is into the final build directory .config whenever an application is compiled for your board.
# If both the common plank_defconfig file and one or more board qualifiers 
# specific plank_<qualifiers>_defconfig files exist, then all matching files will be used. 
# This allows you to place configuration which is common for all board SoCs, CPU clusters, and board variants in the base plank_defconfig
# and only place the adjustments specific for a given SoC or board variant in the plank_<qualifiers>_defconfig.
# The _defconfig should contain mandatory settings for your system clock, console, etc. 
# The results are architecture-specific.

CONFIG_ARM_MPU=y
# Use pinctrl
CONFIG_PINCTRL=y

# enable GPIO
CONFIG_GPIO=y

CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

CONFIG_ZMK_BLE=y

#Backlighting configuration
CONFIG_PWM=y
CONFIG_LED_PWM=y
CONFIG_ZMK_BACKLIGHT=y
CONFIG_ZMK_BACKLIGHT_BRT_START=100
CONFIG_ZMK_BACKLIGHT_AUTO_OFF_IDLE=y

CONFIG_BT_CTLR_TX_PWR_PLUS_8=y
CONFIG_INPUT_THREAD_STACK_SIZE=4096
CONFIG_SYSTEM_WORKQUEUE_STACK_SIZE=4096
CONFIG_ZMK_BLE_THREAD_STACK_SIZE=1536
CONFIG_ZMK_SPLIT_BLE_CENTRAL_SPLIT_RUN_STACK_SIZE=1024

# HID indicators support
CONFIG_ZMK_HID_INDICATORS=y
CONFIG_ZMK_SPLIT_PERIPHERAL_HID_INDICATORS=y

# Sync activity state to peripheral for backlight sync
CONFIG_ZMK_SPLIT_PERIPHERAL_ACTIVITY_SYNC=y

# Breathing LED effect when idle and USB powered
CONFIG_ZMK_BACKLIGHT_BREATHE_IDLE=y
CONFIG_ZMK_BACKLIGHT_BREATHE_SPEED=3
CONFIG_ZMK_BACKLIGHT_BREATHE_TIMEOUT=60
CONFIG_ZMK_SPLIT_PERIPHERAL_BACKLIGHT_BREATHE_SYNC=y

# Battery reporting - use NPM1300 direct I2C read with YDL375678 profile
CONFIG_ZMK_BATTERY_REPORTING_FETCH_MODE_NPM1300_DIRECT=y
CONFIG_ZMK_BATTERY_PROFILE_YDL375678=y

# Fetch peripheral battery level on central
CONFIG_ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_FETCHING=y

# Battery report interval (seconds)
CONFIG_ZMK_BATTERY_REPORT_INTERVAL=60

# Battery low LED indicator
CONFIG_PIPAR_BATTERY_INDICATOR=y
CONFIG_PIPAR_BATTERY_LOW_THRESHOLD=20

